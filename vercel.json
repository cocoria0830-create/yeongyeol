{ 
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/claude.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/gemini.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
